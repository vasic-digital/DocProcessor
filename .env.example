# DocProcessor Configuration
# Copy this file to .env and update values as needed.

# Root directory for documentation files
HELIX_DOCS_ROOT=./docs

# Auto-discover documentation by well-known patterns (true/false)
HELIX_DOCS_AUTO_DISCOVER=true

# Supported file formats (comma-separated, no dots)
HELIX_DOCS_FORMATS=md,yaml,html,adoc,rst
